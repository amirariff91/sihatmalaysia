---
import Base from "../layouts/Base.astro";
import { articles, categories } from "../data/articles";

const featuredArticles = articles.slice(0, 6);
---

<Base
  title="Sihat Malaysia — Portal Kesihatan & Gaya Hidup"
  description="Portal kesihatan Malaysia terpercaya. Artikel kesihatan dalam Bahasa Malaysia, kalkulator BMI, kalkulator kalori dan panduan gaya hidup sihat untuk rakyat Malaysia."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-[#0D7C66] via-[#0a6a55] to-[#085544] text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-white/15 rounded-full px-4 py-1.5 text-sm font-medium mb-6 border border-white/20">
          <span class="w-2 h-2 rounded-full bg-green-300 inline-block animate-pulse"></span>
          Portal Kesihatan #1 Malaysia
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-5">
          Hidup Sihat,<br />
          <span class="text-green-300">Malaysia Cergas</span>
        </h1>
        <p class="text-lg sm:text-xl text-white/85 mb-8 leading-relaxed max-w-2xl">
          Panduan kesihatan berasas bukti saintifik dalam Bahasa Malaysia. Dari diabetes hinggalah ke kesihatan mental — kami sediakan maklumat yang tepat untuk anda.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/artikel/"
            class="inline-flex items-center gap-2 bg-white text-primary font-bold px-6 py-3 rounded-xl transition-all hover:bg-green-50 shadow-lg"
          >
            Baca Artikel →
          </a>
          <a
            href="/kalkulator/"
            class="inline-flex items-center gap-2 bg-white/15 hover:bg-white/25 text-white font-semibold px-6 py-3 rounded-xl transition-all border border-white/30"
          >
            Cuba Kalkulator
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-5">
      <div class="grid grid-cols-3 gap-4 text-center">
        <div>
          <p class="text-2xl sm:text-3xl font-bold text-primary">{articles.length}+</p>
          <p class="text-xs sm:text-sm text-gray-500 mt-0.5">Artikel Kesihatan</p>
        </div>
        <div class="border-x border-gray-100">
          <p class="text-2xl sm:text-3xl font-bold text-primary">3</p>
          <p class="text-xs sm:text-sm text-gray-500 mt-0.5">Kalkulator Percuma</p>
        </div>
        <div>
          <p class="text-2xl sm:text-3xl font-bold text-primary">100%</p>
          <p class="text-xs sm:text-sm text-gray-500 mt-0.5">Berasas Sains</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Topik Kesihatan</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {categories.map(cat => (
        <a
          href={`/artikel/?kategori=${cat.id}`}
          class={`flex items-center gap-2.5 p-3 rounded-xl border border-gray-100 bg-white hover:border-primary hover:shadow-md transition-all group`}
        >
          <span class="text-2xl">{cat.emoji}</span>
          <span class="text-sm font-medium text-gray-700 group-hover:text-primary">{cat.label}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Featured Articles -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-14">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Artikel Terkini</h2>
        <p class="text-gray-500 mt-1">Panduan kesihatan terpilih untuk anda</p>
      </div>
      <a href="/artikel/" class="hidden sm:inline-flex items-center gap-1 text-primary font-semibold hover:text-primary-dark transition-colors text-sm">
        Lihat semua →
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {featuredArticles.map(article => (
        <a
          href={`/artikel/${article.slug}/`}
          class="group bg-white rounded-2xl border border-gray-100 p-5 hover:border-primary hover:shadow-lg transition-all duration-200"
        >
          <div class="flex items-start gap-3 mb-3">
            <span class="text-3xl">{article.image}</span>
            <span class="text-xs px-2 py-1 rounded-full bg-green-100 text-green-700 font-medium mt-0.5">
              {article.categoryLabel}
            </span>
          </div>
          <h3 class="font-bold text-base text-gray-900 group-hover:text-primary transition-colors mb-2 leading-snug">
            {article.title}
          </h3>
          <p class="text-sm text-gray-500 leading-relaxed line-clamp-2">{article.description}</p>
          <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-50">
            <span class="text-xs text-gray-400">⏱ {article.readTime}</span>
            <span class="text-primary text-xs font-semibold group-hover:underline">Baca →</span>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-8 sm:hidden">
      <a href="/artikel/" class="inline-flex items-center gap-1 text-primary font-semibold">
        Lihat semua artikel →
      </a>
    </div>
  </section>

  <!-- Calculators CTA -->
  <section class="bg-gradient-to-r from-primary to-primary-dark py-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="sm:col-span-2 text-white">
          <h2 class="text-2xl sm:text-3xl font-bold mb-3">Kalkulator Kesihatan Percuma</h2>
          <p class="text-white/80 mb-6 text-lg">
            Kira BMI, keperluan kalori harian dan periksa kategori tekanan darah anda — semuanya percuma dan privat.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/kalkulator/" class="inline-flex items-center gap-2 bg-white text-primary font-bold px-6 py-3 rounded-xl hover:bg-green-50 transition-all shadow-lg">
              🧮 Cuba Kalkulator
            </a>
          </div>
        </div>
        <div class="grid grid-cols-1 gap-3">
          <div class="bg-white/10 rounded-xl p-4 border border-white/20">
            <div class="text-2xl mb-1">⚖️</div>
            <h3 class="text-white font-semibold text-sm">Kalkulator BMI</h3>
            <p class="text-white/60 text-xs mt-0.5">Berat badan ideal anda</p>
          </div>
          <div class="bg-white/10 rounded-xl p-4 border border-white/20">
            <div class="text-2xl mb-1">🔥</div>
            <h3 class="text-white font-semibold text-sm">Kalori Harian</h3>
            <p class="text-white/60 text-xs mt-0.5">Keperluan tenaga harian</p>
          </div>
          <div class="bg-white/10 rounded-xl p-4 border border-white/20">
            <div class="text-2xl mb-1">💓</div>
            <h3 class="text-white font-semibold text-sm">Tekanan Darah</h3>
            <p class="text-white/60 text-xs mt-0.5">Periksa kategori anda</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Sihat Malaysia -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-14">
    <div class="max-w-3xl mx-auto text-center mb-10">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">Kenapa Sihat Malaysia?</h2>
      <p class="text-gray-500 leading-relaxed">
        Kami percaya setiap rakyat Malaysia berhak mendapat akses kepada maklumat kesihatan yang tepat dan mudah difahami — dalam bahasa sendiri.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {[
        { icon: '🇲🇾', title: 'Konteks Malaysia', desc: 'Artikel ditulis khas untuk realiti kesihatan Malaysia — makanan, iklim dan sistem penjagaan kesihatan tempatan.' },
        { icon: '🔬', title: 'Berasas Sains', desc: 'Semua maklumat berasaskan kajian perubatan semasa, garis panduan KKM dan WHO.' },
        { icon: '🌐', title: 'Dwibahasa', desc: 'Artikel dalam Bahasa Malaysia dan Inggeris — untuk seluruh keluarga Malaysia.' },
        { icon: '🆓', title: 'Sepenuhnya Percuma', desc: 'Semua artikel dan kalkulator percuma untuk digunakan. Tiada daftar akaun diperlukan.' },
      ].map(item => (
        <div class="bg-white rounded-2xl border border-gray-100 p-5 text-center hover:shadow-md transition-shadow">
          <div class="text-3xl mb-3">{item.icon}</div>
          <h3 class="font-bold text-gray-900 mb-2">{item.title}</h3>
          <p class="text-sm text-gray-500 leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Health Tips Banner -->
  <section class="bg-green-50 border-y border-green-100 py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="text-xl font-bold text-gray-900 mb-6 text-center">Tip Kesihatan Harian</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          { tip: 'Minum 8 gelas air sehari untuk kekalkan tahap hidrasi dan sokongan fungsi organ.', icon: '💧', label: 'Hidrasi' },
          { tip: 'Tidur 7-9 jam setiap malam — tidur yang cukup setara dengan ubat terbaik untuk badan.', icon: '😴', label: 'Tidur' },
          { tip: 'Bersenam minimum 30 minit, 5 kali seminggu. Jalan kaki pun sudah mencukupi!', icon: '🏃', label: 'Aktif' },
        ].map(item => (
          <div class="flex items-start gap-3 bg-white rounded-xl p-4 border border-green-100">
            <div class="text-2xl flex-shrink-0">{item.icon}</div>
            <div>
              <p class="text-xs font-semibold text-primary uppercase tracking-wider mb-1">{item.label}</p>
              <p class="text-sm text-gray-600 leading-relaxed">{item.tip}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
