---
import Base from "../../layouts/Base.astro";
import { articles, categories } from "../../data/articles";
---

<Base
  title="Artikel Kesihatan — Sihat Malaysia"
  description="Koleksi artikel kesihatan dalam Bahasa Malaysia. Baca panduan diabetes, diet sihat, senaman, kesihatan mental, tekanan darah dan lebih banyak lagi."
>
  <!-- Header -->
  <section class="bg-gradient-to-br from-primary to-primary-dark text-white py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h1 class="text-3xl sm:text-4xl font-bold mb-3">Artikel Kesihatan</h1>
      <p class="text-white/80 text-lg max-w-2xl">
        Panduan kesihatan berasas bukti dalam Bahasa Malaysia. Semua artikel ditulis untuk membantu anda membuat keputusan kesihatan yang lebih baik.
      </p>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <!-- Category Filter -->
    <div class="flex flex-wrap gap-2 mb-8">
      <button class="px-4 py-2 rounded-full bg-primary text-white text-sm font-medium">
        Semua
      </button>
      {categories.map(cat => (
        <button class="px-4 py-2 rounded-full bg-white border border-gray-200 text-gray-700 text-sm font-medium hover:border-primary hover:text-primary transition-colors">
          {cat.emoji} {cat.label}
        </button>
      ))}
    </div>

    <!-- Articles Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {articles.map(article => (
        <a
          href={`/artikel/${article.slug}/`}
          class="group bg-white rounded-2xl border border-gray-100 overflow-hidden hover:border-primary hover:shadow-lg transition-all duration-200"
        >
          <div class="p-5">
            <div class="flex items-start gap-3 mb-3">
              <span class="text-3xl">{article.image}</span>
              <div class="flex-1 min-w-0">
                <span class="text-xs px-2 py-1 rounded-full bg-green-100 text-green-700 font-medium">
                  {article.categoryLabel}
                </span>
              </div>
            </div>
            <h2 class="font-bold text-base text-gray-900 group-hover:text-primary transition-colors mb-2 leading-snug">
              {article.title}
            </h2>
            <p class="text-sm text-gray-500 leading-relaxed line-clamp-3">{article.description}</p>
            <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-50">
              <div class="flex items-center gap-3 text-xs text-gray-400">
                <span>⏱ {article.readTime}</span>
                <span>📅 {new Date(article.date).toLocaleDateString('ms-MY', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
              </div>
              <span class="text-primary text-xs font-semibold group-hover:underline">Baca →</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
